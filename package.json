{
  "name": "webhook-delivery",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter @webhook/api dev\" \"pnpm --filter @webhook/worker dev\" \"pnpm --filter @webhook/web dev\"",
    "build": "pnpm -r build",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm --filter @webhook/api test:integration && pnpm --filter @webhook/worker test:integration",
    "typecheck": "tsc --build && pnpm --filter @webhook/api exec tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "pnpm --filter @webhook/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test:smoke": "playwright test",
    "test:smoke:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "react-doctor": "^0.5.0",
    "typescript": "^5.7.2"
  }
}
