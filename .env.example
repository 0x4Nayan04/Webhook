# ── API ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://webhook:webhook@localhost:5432/webhooks
REDIS_URL=redis://localhost:6379

# ── Security ─────────────────────────────────────
# Used only for POST /v1/auth/bootstrap (and the legacy CLI tenant path in non-production).
# Generate with: openssl rand -hex 32
# In production, must be ≥32 chars and must not be the default placeholder below.
ADMIN_BOOTSTRAP_SECRET=change-me-in-production
SESSION_SECRET=change-me-session-secret-min-32-chars
SESSION_COOKIE_MAX_AGE=604800000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
WEB_APP_URL=http://localhost:5173
# INVITE_TTL_MS=604800000
# Ingest: fixed-window limit per tenant (POST /v1/events)
INGEST_RATE_LIMIT_PER_MINUTE=120

# ── Worker ───────────────────────────────────────
DELIVERY_TIMEOUT_MS=30000
MAX_DELIVERY_ATTEMPTS=5
RATE_LIMIT_PER_MINUTE=100
WORKER_CONCURRENCY=5

# ── Frontend (build-time) ────────────────────────
VITE_API_URL=http://localhost:3000
# Optional — overrides footer GitHub / X links (defaults to the public Hikyaku repo + X profile)
# VITE_GITHUB_URL=https://github.com/0x4Nayan04/Hikyaku
# VITE_SOCIAL_URL=https://x.com/NayanSwarnkar04

# ── Logging ──────────────────────────────────────
LOG_LEVEL=info

# ── Dev seed (optional) ──────────────────────────
# Creates a super-admin when no users exist. Dev/CI only — omit in production.
# SEED_SUPER_ADMIN_EMAIL=admin@localhost
# SEED_SUPER_ADMIN_PASSWORD=dev-password-min-12-chars
# SEED_SUPER_ADMIN_NAME=Dev Admin
